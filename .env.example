# =============================================================================
# Cognitive Load Analysis - Unified Environment Template
# Fill in values marked with: <YOUR_...>
# =============================================================================

# =============================================================================
# Frontend (Vite) - Required by src/
# =============================================================================
VITE_ENVIRONMENT=development
VITE_LOG_LEVEL=info

# Frontend -> Backend URLs
VITE_API_URL=http://localhost:3001/api
VITE_API_BASE_URL=http://localhost:3001
VITE_BEHAVIORAL_SERVICE_URL=http://localhost:8000

# Frontend Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_REAL_TIME=false

# Frontend AI/API keys
VITE_OPENAI_API_KEY=<YOUR_OPENAI_API_KEY_OPTIONAL>
VITE_GROK_API_KEY=<YOUR_GROK_API_KEY_OPTIONAL>
VITE_GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>
VITE_GEMINI_CHAT_API_KEY=<YOUR_GEMINI_CHAT_API_KEY_OPTIONAL>
VITE_GEMINI_QUESTIONS_API_KEY=<YOUR_GEMINI_QUESTIONS_API_KEY_OPTIONAL>
VITE_GOOGLE_SEARCH_API_KEY=<YOUR_GOOGLE_SEARCH_API_KEY_OPTIONAL>
VITE_GOOGLE_SEARCH_ENGINE_ID=<YOUR_GOOGLE_SEARCH_ENGINE_ID_OPTIONAL>

# Frontend Supabase
VITE_SUPABASE_URL=<YOUR_SUPABASE_URL>
VITE_SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>


# =============================================================================
# Express Backend (server/) - Required by server/src
# =============================================================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase (backend)
SUPABASE_URL=<YOUR_SUPABASE_URL>
SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY>
DATABASE_URL=<YOUR_DATABASE_URL_OPTIONAL>

# Backend service integration
BEHAVIORAL_SERVICE_URL=http://localhost:8000
BEHAVIORAL_SERVICE_TIMEOUT=5000

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Server-side AI key
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>


# =============================================================================
# FastAPI Behavioral Service (behavioral-service/) - Required by behavioral-service/src
# =============================================================================
FASTAPI_ENV=development
HOST=0.0.0.0

# Keep CORS aligned with frontend dev URL
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional behavioral tuning
LOG_LEVEL=INFO
MODEL_PATH=data/models/cognitive_load_classifier.joblib
MOUSE_SAMPLE_RATE_MS=100
RAGE_CLICK_THRESHOLD=3
RAGE_CLICK_WINDOW_MS=500
