# Cognitive Load Analysis Platform - Environment Configuration

# =============================================================================
# API Keys (Frontend)
# =============================================================================

# OpenAI ChatGPT API
VITE_OPENAI_API_KEY=your-openai-api-key

# xAI Grok API (should start with "xai-")
VITE_GROK_API_KEY=your-grok-api-key

# Google Gemini API (should start with "AIza")
VITE_GEMINI_API_KEY=your-gemini-api-key

# Google Custom Search (optional)
VITE_GOOGLE_SEARCH_API_KEY=your-google-search-api-key
VITE_GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# =============================================================================
# Backend Configuration
# =============================================================================

# Backend API URL
VITE_API_URL=http://localhost:3001/api

# Behavioral Service URL (FastAPI)
VITE_BEHAVIORAL_SERVICE_URL=http://localhost:8000

# =============================================================================
# Feature Flags
# =============================================================================

# Enable analytics tracking
VITE_ENABLE_ANALYTICS=false

# Enable real-time features
VITE_ENABLE_REAL_TIME=false

# =============================================================================
# Environment
# =============================================================================

VITE_ENVIRONMENT=development

# =============================================================================
# Supabase Configuration (Phase 2: Database Integration)
# =============================================================================

# Supabase Project URL
# Get from: Supabase Dashboard → Project Settings → API → Project URL
# Format: https://xxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=your-supabase-project-url

# Supabase Anonymous/Public Key (Safe for frontend)
# Get from: Supabase Dashboard → Project Settings → API → Project API keys → anon/public
# Starts with: eyJhbG...
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role Key (BACKEND ONLY - Keep Secret!)
# Get from: Supabase Dashboard → Project Settings → API → Project API keys → service_role
# Starts with: eyJhbG...
# WARNING: Never expose this key in frontend code!
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Database Connection String (Optional - for direct PostgreSQL access)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Format: postgresql://postgres:[password]@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=your-database-connection-string
