# Server Configuration
PORT=3001
NODE_ENV=development

# =============================================================================
# Database Configuration (Phase 2: Supabase PostgreSQL)
# =============================================================================

# Supabase Project URL
# Get from: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=your-supabase-project-url

# Supabase Service Role Key (BACKEND ONLY - Never expose to frontend!)
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Supabase Anon/Public Key (for user authentication on backend)
# Get from: Supabase Dashboard → Project Settings → API → anon/public key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Direct PostgreSQL Connection (Optional - for advanced queries)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
# Format: postgresql://postgres:[password]@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=your-database-connection-string

# =============================================================================
# API Keys (Server-side only)
# =============================================================================

# Google Gemini API Key (for AI features: chat, assessments, creativity evaluation)
GEMINI_API_KEY=your-gemini-api-key

# =============================================================================
# Application Configuration
# =============================================================================

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Redis for caching (Optional)
REDIS_URL=redis://localhost:6379
