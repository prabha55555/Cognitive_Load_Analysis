# Behavioral Service Configuration

# =============================================================================
# Server Configuration
# =============================================================================

# Environment (development, production)
FASTAPI_ENV=development

# Server host and port
HOST=0.0.0.0
PORT=8000

# =============================================================================
# Logging
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# Model Configuration
# =============================================================================

# Path to trained cognitive load classifier model
MODEL_PATH=data/models/cognitive_load_classifier.joblib

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Feature Extraction
# =============================================================================

# Mouse sampling rate in milliseconds
MOUSE_SAMPLE_RATE_MS=100

# Rage click detection threshold (clicks within time window)
RAGE_CLICK_THRESHOLD=3
RAGE_CLICK_WINDOW_MS=500
